# LLM - Google Gemini
GOOGLE_API_KEY=your-gemini-api-key-here

# LlamaParse (alternative ingestion pipeline)
LLAMA_CLOUD_API_KEY=llx-your-llamaparse-api-key-here

# Neon PostgreSQL (document dedup registry + persistent chat history)
# Pooler URL — used by the app at runtime (pgBouncer, connection pooling)
DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Direct URL — used only for schema creation (CREATE TABLE IF NOT EXISTS) on startup
DATABASE_URL_DIRECT=postgresql+psycopg://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Vector DB (Pinecone)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=agentic-rag-index

# LangSmith (optional - for tracing)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=agentic-rag
